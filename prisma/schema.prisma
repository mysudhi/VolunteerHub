generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SuperAdmin
  OrgAdmin
  Contributor
}

enum ShiftStatus {
  DRAFT
  OPEN
  FILLED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum EventSource {
  INTERNAL
  ICAL_IMPORT
}

model Organization {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  logoUrl       String?
  primaryColor  String?         @default("#2563eb")
  fontFamily    String?         @default("Inter")
  timezone      String          @default("UTC")
  isActive      Boolean         @default(true)
  users         User[]
  shifts        Shift[]
  tasks         Task[]
  skills        Skill[]
  calendarEvents CalendarEvent[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([isActive])
}

model User {
  id                  String              @id @default(cuid())
  organizationId      String?
  email               String              @unique
  firstName           String
  lastName            String
  passwordHash        String?
  googleId            String?             @unique
  role                Role                @default(Contributor)
  isActive            Boolean             @default(true)
  phone               String?
  organization        Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  assignedTasks       Task[]              @relation("TaskAssignee")
  createdEvents       CalendarEvent[]     @relation("EventCreator")
  shiftAssignments    ShiftContributor[]
  createdShifts       Shift[]             @relation("ShiftCreator")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  @@index([organizationId, role])
  @@index([isActive])
}

model Shift {
  id                String             @id @default(cuid())
  organizationId    String
  createdById       String?
  title             String
  description       String?
  location          String?
  startsAt          DateTime
  endsAt            DateTime
  capacity          Int                @default(1)
  status            ShiftStatus        @default(OPEN)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         User?              @relation("ShiftCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tasks             Task[]
  requiredSkills    ShiftSkill[]
  contributorLinks  ShiftContributor[]
  calendarEvents    CalendarEvent[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  @@index([organizationId, startsAt, endsAt])
  @@index([organizationId, status])
}

model Task {
  id                    String         @id @default(cuid())
  organizationId        String
  shiftId               String
  assignedContributorId String?
  title                 String
  details               String?
  sortOrder             Int            @default(0)
  status                TaskStatus     @default(TODO)
  dueAt                 DateTime?
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shift                 Shift          @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  assignedContributor   User?          @relation("TaskAssignee", fields: [assignedContributorId], references: [id], onDelete: SetNull)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  deletedAt             DateTime?

  @@index([organizationId, status])
  @@index([shiftId, status])
}

model Skill {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  description    String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shiftLinks     ShiftSkill[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, name])
  @@index([organizationId])
}

model CalendarEvent {
  id             String       @id @default(cuid())
  organizationId String
  shiftId        String?
  createdById    String?
  title          String
  description    String?
  startsAt       DateTime
  endsAt         DateTime
  source         EventSource  @default(INTERNAL)
  externalUid    String?
  isAllDay       Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shift          Shift?       @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  createdBy      User?        @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, externalUid])
  @@index([organizationId, startsAt, endsAt])
}

model ShiftSkill {
  shiftId     String
  skillId     String
  shift       Shift      @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  skill       Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@id([shiftId, skillId])
}

model ShiftContributor {
  shiftId     String
  userId      String
  assignedAt  DateTime   @default(now())
  shift       Shift      @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  contributor User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@id([shiftId, userId])
  @@index([userId, assignedAt])
}
